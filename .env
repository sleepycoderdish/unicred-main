# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Backend API base URL (no trailing slash)
# In dev, Vite proxy rewrites /api → VITE_API_BASE_URL so you can leave this empty
# In production, set this to your deployed backend URL
VITE_API_BASE_URL=http://localhost:5000

# App name shown in browser tab and metadata
VITE_APP_NAME=Unicred

# Set to "true" to use local mock data instead of real API calls.
# Useful when backend endpoints are not yet ready.
VITE_USE_MOCK=false

# Cookie domain for refresh token (set by backend, but useful to document here)
# VITE_COOKIE_DOMAIN=localhost