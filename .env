# .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Backend API base URL (no trailing slash)
# In dev, leave this EMPTY so axios uses relative /api paths that the Vite
# proxy (see vite.config.js) forwards to the backend (localhost:5001).
# Going through the proxy keeps requests same-origin, so the HttpOnly
# refresh-token cookie works without any CORS setup.
# In production, set this to your deployed backend URL.
VITE_API_BASE_URL=http://localhost:5001

# App name shown in browser tab and metadata
VITE_APP_NAME=Unicred

# Set to "true" to use local mock data instead of real API calls.
# Useful when backend endpoints are not yet ready.
VITE_USE_MOCK=false

# Cookie domain for refresh token (set by backend, but useful to document here)
# VITE_COOKIE_DOMAIN=localhost